# AT Protocol App Wizard — Environment Variables
#
# Copy this file to .env.local and fill in values for production builds.
# These are NOT needed for local development (npm run dev).

# OAuth redirect URI (where the auth provider sends the user back after login)
VITE_OAUTH_REDIRECT_URI=https://your-app.example.com

# OAuth client metadata URL (registered with your AT Protocol auth provider)
VITE_OAUTH_CLIENT_ID=https://your-app.example.com/client-metadata.json

# App base URL (the public URL where the app is hosted)
VITE_APP_BASE_URL=https://your-app.example.com
